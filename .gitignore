# Dependencies — never commit these
/node_modules

# Next.js build output — generated locally, not needed in git
/.next/
/out/
/build

# Environment variables — contain secrets, never commit
.env*

# AI development tooling (ruflo / Claude Code) — local only
.claude/
.claude-flow/
.swarm/
.mcp.json
ruvector.db

# OS / editor junk
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# Vercel deployment config
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test reports and results
/test-results/
/playwright-report/
.vscode/

